{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rowpic",
  "version": "0.1.0",
  "identifier": "com.rowpic.app",
  "build": {
    "beforeDevCommand": "npm --prefix ../frontend run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm --prefix ../frontend run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "rowpic",
        "width": 1480,
        "height": 920,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#0e1014"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "resources": [],
    "externalBin": [],
    "category": "Photo",
    "shortDescription": "Photo viewer & analyzer (RAW + standard)",
    "longDescription": "rowpic — a photo viewer & analyzer supporting RAW formats, with composition guides, focus / face blur detection, one-click classification, and AI-assisted color grading."
  }
}
