# Backend
ROWPIC_HOST=127.0.0.1
ROWPIC_PORT=8765
ROWPIC_RELOAD=0
ROWPIC_WORKERS=1

# AI color grading (set to true to enable the deep-learning path)
ROWPIC_ENABLE_AI_COLOR=false
ROWPIC_AI_COLOR_MODEL=auto

# Focus / face analysis
ROWPIC_BLUR_THRESHOLD=60
ROWPIC_FACE_BLUR_THRESHOLD=35

# Comma-separated list of paths the scanner is allowed to access.
# If empty, any path is allowed (desktop mode).
ROWPIC_ALLOWED_ROOTS=
